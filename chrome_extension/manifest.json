{
  "manifest_version": 3,
  "name": "DemoX Event Capture",
  "version": "1.0.0",
  "description": "Captures instructor browsing events for DemoX AI demo training",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
